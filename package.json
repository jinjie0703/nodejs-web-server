{
  "name": "my-http-server",
  "version": "1.0.0",
  "description": "",
  "bin": "dist/index.js",
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "public/**/*",
      "www/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "build": "tsc && pkg . --out-path ./build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
